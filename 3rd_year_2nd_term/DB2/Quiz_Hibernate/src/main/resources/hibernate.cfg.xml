<hibernate-configuration>
    <session-factory>
        <!-- Oracle connection -->
        <property name="connection.driver_class">
            oracle.jdbc.OracleDriver
        </property>

        <property name="connection.url">jdbc:oracle:thin:@localhost:1521/orclpdb</property>

        <property name="connection.username">system</property>
        <property name="connection.password">system</property>
        <!--        <property name="dialect">org.hibernate.dialect.Oracle8iDialect</property>-->
        <property name="hibernate.dialect">org.hibernate.dialect.Oracle12cDialect</property>
        <!-- Display generated SQL -->
        <property name="show_sql">true</property>
        <property name="hibernate.format_sql">true</property>
        <!--        <property name="hibernate.use_sql_comments">true</property>-->

        <!-- Lazy loading outside session -->
        <property name="enable_lazy_load_no_trans">true</property>
        <!--        -->

        <property name="hbm2ddl.auto">update</property>
<!--                <property name="hbm2ddl.auto">create</property>-->
        <!-- Entity mappings -->
        <mapping class="com.sci.models.Employe"/>
        <mapping class="com.sci.models.Passport"/>
        <mapping class="com.sci.models.Project"/>
        <!--        ...-->
    </session-factory>
</hibernate-configuration>